# Required: long random string for signing session cookies
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Database file path
# Default in dev: ./data/tipsplit.db
# Default in container: /app/data/tipsplit.db
DATABASE_PATH=./data/tipsplit.db

# Bootstrap: PIN for the first manager account (only used if no users exist)
# Remove or leave blank after first login
INITIAL_MANAGER_PIN=

# Google Sheets integration (optional — can also configure in Settings UI)
# Paste service account JSON as a single line
GOOGLE_SERVICE_ACCOUNT_JSON=
